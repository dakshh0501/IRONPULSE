rules_version = '2';

// ══════════════════════════════════════════════════════════
//  IRONPULSE — Firestore Security Rules
//  Roles: super_admin | gym_admin | trainer | member | pending | gym_owner_pending
//  Legacy aliases: admin + isSuperAdmin → super_admin, gym_owner → gym_admin
// ══════════════════════════════════════════════════════════

service cloud.firestore {

  match /databases/{database}/documents {

    // ── HELPERS ───────────────────────────────────────────

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAuthed() {
      return request.auth != null;
    }

    // Super admin: admin role with isSuperAdmin flag on user doc
    function isSuperAdmin() {
      return isAuthed() && (
        getRole() == 'super_admin' ||
        (getRole() == 'admin' &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true)
      );
    }

    // Gym-level admin: gym_admin role OR gym_owner role OR legacy admin (non-super)
    function isGymAdmin() {
      return isAuthed() && (
        getRole() == 'gym_admin' ||
        getRole() == 'gym_owner' ||
        (getRole() == 'admin' &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin != true)
      );
    }

    function isTrainer() {
      return isAuthed() && getRole() == 'trainer';
    }

    function isMember() {
      return isAuthed() && getRole() == 'member';
    }

    // Platform staff: super admin or gym admin
    function isAdminOrOwner() {
      return isSuperAdmin() || isGymAdmin();
    }

    // Staff: anyone managing the gym (super admin, gym admin, trainer)
    function isStaff() {
      return isSuperAdmin() || isGymAdmin() || isTrainer();
    }

    // Approved users who can read plans etc.
    function isApproved() {
      return isAuthed() && (
        getRole() == 'super_admin' ||
        getRole() == 'gym_admin' ||
        getRole() == 'gym_owner' ||
        getRole() == 'trainer' ||
        getRole() == 'member' ||
        (getRole() == 'admin')
      );
    }

    function isOwnAttendance(resourceMemberId) {
      return isMember() && resourceMemberId == request.auth.uid;
    }

    function isOwnMemberDoc(resourceMemberId) {
      let memberPath = /databases/$(database)/documents/members/$(resourceMemberId);
      return isMember() &&
        exists(memberPath) &&
        get(memberPath).data.authUid == request.auth.uid;
    }

    // ════════════════════════════════════════════════════════
    //  USERS
    // ════════════════════════════════════════════════════════
    match /users/{uid} {

      allow read: if isAuthed() && (
        request.auth.uid == uid || isStaff()
      );

      allow create: if (isAuthed() && request.auth.uid == uid) || isStaff();

      allow update: if isAuthed() && (
        (request.auth.uid == uid &&
          request.resource.data.role == resource.data.role)
        || isStaff()
      );

      allow delete: if isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  MEMBERS
    // ════════════════════════════════════════════════════════
    match /members/{memberId} {

      allow read: if isStaff() || (
        isMember() &&
        resource.data.authUid == request.auth.uid
      );

      allow create: if isAdminOrOwner();
      allow update: if isAdminOrOwner() || (
        isTrainer() &&
        request.resource.data.amountPaid == resource.data.amountPaid &&
        request.resource.data.planPrice == resource.data.planPrice
      );
      allow delete: if isAdminOrOwner();
    }

    // ════════════════════════════════════════════════════════
    //  TRAINERS
    // ════════════════════════════════════════════════════════
    match /trainers/{trainerId} {

      allow read: if isStaff();
      allow create: if isAdminOrOwner();
      allow update: if isAdminOrOwner();
      allow delete: if isAdminOrOwner();
    }

    // ════════════════════════════════════════════════════════
    //  PAYMENTS
    // ════════════════════════════════════════════════════════
    match /payments/{paymentId} {

      allow read: if isAdminOrOwner() || isOwnMemberDoc(resource.data.memberId);
      allow create: if isAdminOrOwner();
      allow update: if isAdminOrOwner();
      allow delete: if isAdminOrOwner();
    }

    // ════════════════════════════════════════════════════════
    //  ATTENDANCE
    // ════════════════════════════════════════════════════════
    match /attendance/{attendanceId} {

      allow read: if isStaff() || isOwnAttendance(resource.data.memberId);
      allow create: if isStaff() || (
        isMember() &&
        request.resource.data.memberId == request.auth.uid
      );
      allow update: if isAdminOrOwner();
      allow delete: if isAdminOrOwner();
    }

    // ════════════════════════════════════════════════════════
    //  PLANS (membership pricing)
    // ════════════════════════════════════════════════════════
    match /plans/{planId} {

      allow read: if isApproved();
      allow create: if isSuperAdmin() || isGymAdmin();
      allow update: if isSuperAdmin() || isGymAdmin();
      allow delete: if isSuperAdmin() || isGymAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  DIET PLANS
    // ════════════════════════════════════════════════════════
    match /dietPlans/{planId} {

      allow read: if isStaff() || (
        isMember() &&
        (resource.data.memberId == request.auth.uid ||
         resource.data.authUid == request.auth.uid)
      );
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdminOrOwner();
    }

    // ════════════════════════════════════════════════════════
    //  WORKOUT PLANS
    // ════════════════════════════════════════════════════════
    match /workoutPlans/{planId} {

      allow read: if isStaff() || (
        isMember() &&
        (resource.data.memberId == request.auth.uid ||
         resource.data.authUid == request.auth.uid)
      );
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdminOrOwner();
    }

    // ════════════════════════════════════════════════════════
    //  PROGRESS LOGS
    // ════════════════════════════════════════════════════════
    match /progressLogs/{logId} {

      allow read: if isStaff() || isOwnMemberDoc(resource.data.memberId);
      allow create: if isStaff() || (
        isMember() &&
        isOwnMemberDoc(request.resource.data.memberId)
      );
      allow update: if isAdminOrOwner();
      allow delete: if isAdminOrOwner();
    }

    // ════════════════════════════════════════════════════════
    //  SUPPORT TICKETS
    // ════════════════════════════════════════════════════════
    match /supportTickets/{ticketId} {

      allow read: if isAdminOrOwner();
      allow create: if isAuthed();
      allow update: if isAdminOrOwner();
      allow delete: if isAdminOrOwner();
    }

    // ════════════════════════════════════════════════════════
    //  FEATURE REQUESTS
    // ════════════════════════════════════════════════════════
    match /featureRequests/{requestId} {

      allow read: if isAdminOrOwner();
      allow create: if isAuthed();
      allow update: if isAdminOrOwner();
      allow delete: if isAdminOrOwner();
    }

    // ════════════════════════════════════════════════════════
    //  SETTINGS
    // ════════════════════════════════════════════════════════
    match /settings/{docId} {

      allow read: if isAdminOrOwner() || (
        isApproved() &&
        (docId == 'gym' || docId.matches('.*:gym$'))
      );
      allow create: if isAdminOrOwner();
      allow update: if isAdminOrOwner();
      allow delete: if isAdminOrOwner();
    }

    // ════════════════════════════════════════════════════════
    //  GYMS (global — multi-tenant registry)
    // ════════════════════════════════════════════════════════
    match /gyms/{gymId} {

      allow read: if isStaff();
      allow create: if isSuperAdmin() || (
        isAuthed() &&
        request.resource.data.ownerUid == request.auth.uid
      );
      allow update: if isAdminOrOwner();
      allow delete: if isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  SUBSCRIPTIONS (global — billing per gym)
    // ════════════════════════════════════════════════════════
    match /subscriptions/{subId} {

      allow read: if isAdminOrOwner();
      allow create: if isAdminOrOwner();
      allow update: if isAdminOrOwner();
      allow delete: if isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  PAYMENT ATTEMPTS (PhonePe integration)
    // ════════════════════════════════════════════════════════
    match /paymentAttempts/{attemptId} {

      allow read: if isAdminOrOwner();
      allow create: if isAdminOrOwner();
      allow update: if isAdminOrOwner();
      allow delete: if isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  NOTIFICATIONS
    // ════════════════════════════════════════════════════════
    match /notifications/{notifId} {

      allow read: if isSuperAdmin() || (
        isAuthed() &&
        resource.data.userId == request.auth.uid
      );

      allow create: if isAuthed();

      allow update: if isSuperAdmin() || (
        isAuthed() &&
        resource.data.userId == request.auth.uid
      );

      allow delete: if isSuperAdmin() || (
        isAuthed() &&
        resource.data.userId == request.auth.uid
      );
    }

  } // end match /databases/{database}/documents
} // end service cloud.firestore

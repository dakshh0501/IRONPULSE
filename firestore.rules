rules_version = '2';

// ══════════════════════════════════════════════════════════
//  IRONPULSE — Firestore Security Rules
//  Roles: super_admin | gym_admin | trainer | member | pending | gym_owner_pending
//  Legacy aliases: admin + isSuperAdmin → super_admin, gym_owner → gym_admin
// ══════════════════════════════════════════════════════════

service cloud.firestore {

  match /databases/{database}/documents {

    // ── HELPERS ───────────────────────────────────────────

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAuthed() {
      return request.auth != null;
    }

    // Super admin: admin role with isSuperAdmin flag on user doc
    function isSuperAdmin() {
      return isAuthed() && (
        getRole() == 'super_admin' ||
        (getRole() == 'admin' &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true)
      );
    }

    // Gym-level admin: gym_admin role OR gym_owner role OR legacy admin (non-super)
    function isGymAdmin() {
      return isAuthed() && (
        getRole() == 'gym_admin' ||
        getRole() == 'gym_owner' ||
        (getRole() == 'admin' &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin != true)
      );
    }

    function isTrainer() {
      return isAuthed() && getRole() == 'trainer';
    }

    function isMember() {
      return isAuthed() && getRole() == 'member';
    }

    // Platform staff: super admin or gym admin
    function isAdminOrOwner() {
      return isSuperAdmin() || isGymAdmin();
    }

    // Staff: anyone managing the gym (super admin, gym admin, trainer)
    function isStaff() {
      return isSuperAdmin() || isGymAdmin() || isTrainer();
    }

    // Approved users who can read plans etc.
    function isApproved() {
      return isAuthed() && (
        getRole() == 'super_admin' ||
        getRole() == 'gym_admin' ||
        getRole() == 'gym_owner' ||
        getRole() == 'trainer' ||
        getRole() == 'member' ||
        (getRole() == 'admin')
      );
    }

    function getCallerGymId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.gymId;
    }

    function isOwnAttendance(resourceMemberId) {
      return isMember() &&
        exists(/databases/$(database)/documents/members/$(resourceMemberId)) &&
        get(/databases/$(database)/documents/members/$(resourceMemberId)).data.authUid == request.auth.uid;
    }

    function isOwnMemberDoc(resourceMemberId) {
      let memberPath = /databases/$(database)/documents/members/$(resourceMemberId);
      return isMember() &&
        exists(memberPath) &&
        get(memberPath).data.authUid == request.auth.uid;
    }

    // Helper: check if the resource belongs to the caller's gym (super_admin bypasses)
    function inCallersGym() {
      return isSuperAdmin() || resource.data.gymId == getCallerGymId();
    }

    // Helper: check if the incoming data belongs to the caller's gym (for create)
    function inCallersGymCreate() {
      return isSuperAdmin() || request.resource.data.gymId == getCallerGymId();
    }

    // ════════════════════════════════════════════════════════
    //  USERS
    // ════════════════════════════════════════════════════════
    match /users/{uid} {

      allow read: if isAuthed() && (
        request.auth.uid == uid || isStaff()
      );

      allow create: if (isAuthed() && request.auth.uid == uid) || isStaff();

      allow update: if isAuthed() && (
        (request.auth.uid == uid &&
          request.resource.data.role == resource.data.role)
        || isStaff()
      );

      allow delete: if isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  MEMBERS (gym-scoped)
    // ════════════════════════════════════════════════════════
    match /members/{memberId} {

      allow read: if (isStaff() && inCallersGym()) || (
        isMember() &&
        resource.data.authUid == request.auth.uid
      );

      allow create: if isAdminOrOwner() && inCallersGymCreate();
      allow update: if (isAdminOrOwner() && inCallersGym()) || (
        isTrainer() && inCallersGym() &&
        request.resource.data.amountPaid == resource.data.amountPaid &&
        request.resource.data.planPrice == resource.data.planPrice
      );
      allow delete: if isAdminOrOwner() && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  TRAINERS (gym-scoped)
    // ════════════════════════════════════════════════════════
    match /trainers/{trainerId} {

      allow read: if isStaff() && inCallersGym();
      allow create: if isAdminOrOwner() && inCallersGymCreate();
      allow update: if isAdminOrOwner() && inCallersGym();
      allow delete: if isAdminOrOwner() && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  PAYMENTS (gym-scoped)
    // ════════════════════════════════════════════════════════
    match /payments/{paymentId} {

      allow read: if (isAdminOrOwner() && inCallersGym()) || (
        resource.data.gymId == getCallerGymId() && (
          isOwnMemberDoc(resource.data.memberId) ||
          (isMember() && resource.data.authUid == request.auth.uid)
        )
      );
      allow create: if isAdminOrOwner() && inCallersGymCreate();
      allow update: if isAdminOrOwner() && inCallersGym();
      allow delete: if isAdminOrOwner() && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  ATTENDANCE (gym-scoped)
    // ════════════════════════════════════════════════════════
    match /attendance/{attendanceId} {

      allow read: if (isStaff() && inCallersGym()) || isOwnAttendance(resource.data.memberId);
      allow create: if (isStaff() && inCallersGymCreate()) || (
        isMember() &&
        exists(/databases/$(database)/documents/members/$(request.resource.data.memberId)) &&
        get(/databases/$(database)/documents/members/$(request.resource.data.memberId)).data.authUid == request.auth.uid
      );
      allow update: if isAdminOrOwner() && inCallersGym();
      allow delete: if isAdminOrOwner() && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  PLANS (gym-scoped — membership pricing)
    // ════════════════════════════════════════════════════════
    match /plans/{planId} {

      allow read: if isApproved() && inCallersGym();
      allow create: if (isSuperAdmin() || isGymAdmin()) && inCallersGymCreate();
      allow update: if (isSuperAdmin() || isGymAdmin()) && inCallersGym();
      allow delete: if (isSuperAdmin() || isGymAdmin()) && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  DIET PLANS (gym-scoped)
    // ════════════════════════════════════════════════════════
    match /dietPlans/{planId} {

      allow read: if (isStaff() && inCallersGym()) || (
        isMember() &&
        (resource.data.memberId == request.auth.uid ||
         resource.data.authUid == request.auth.uid)
      );
      allow create: if isStaff() && inCallersGymCreate();
      allow update: if isStaff() && inCallersGym();
      allow delete: if isAdminOrOwner() && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  WORKOUT PLANS (gym-scoped)
    // ════════════════════════════════════════════════════════
    match /workoutPlans/{planId} {

      allow read: if (isStaff() && inCallersGym()) || (
        isMember() &&
        (resource.data.memberId == request.auth.uid ||
         resource.data.authUid == request.auth.uid)
      );
      allow create: if isStaff() && inCallersGymCreate();
      allow update: if isStaff() && inCallersGym();
      allow delete: if isAdminOrOwner() && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  PROGRESS LOGS (gym-scoped)
    // ════════════════════════════════════════════════════════
    match /progressLogs/{logId} {

      allow read: if (isStaff() && inCallersGym()) || isOwnMemberDoc(resource.data.memberId);
      allow create: if (isStaff() && inCallersGymCreate()) || (
        isMember() &&
        isOwnMemberDoc(request.resource.data.memberId)
      );
      allow update: if isAdminOrOwner() && inCallersGym();
      allow delete: if isAdminOrOwner() && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  SUPPORT TICKETS (gym-scoped)
    // ════════════════════════════════════════════════════════
    match /supportTickets/{ticketId} {

      allow read: if (isAdminOrOwner() && inCallersGym()) || (
        isAuthed() && resource.data.createdBy == request.auth.uid
      );
      allow create: if isAuthed() && inCallersGymCreate();
      allow update: if isAdminOrOwner() && inCallersGym();
      allow delete: if isAdminOrOwner() && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  FEATURE REQUESTS (gym-scoped)
    // ════════════════════════════════════════════════════════
    match /featureRequests/{requestId} {

      allow read: if (isAdminOrOwner() && inCallersGym()) || (
        isAuthed() && resource.data.createdBy == request.auth.uid
      );
      allow create: if isAuthed() && inCallersGymCreate();
      allow update: if isAdminOrOwner() && inCallersGym();
      allow delete: if isAdminOrOwner() && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  SETTINGS (gym-scoped via composite key pattern)
    // ════════════════════════════════════════════════════════
    match /settings/{docId} {

      allow read: if (isAdminOrOwner() && inCallersGym()) || (
        isApproved() &&
        (docId == 'gym' || docId.matches('.*:gym$') || docId == 'theme' || docId.matches('.*:theme$'))
      );
      allow create: if isAdminOrOwner() && inCallersGymCreate();
      allow update: if isAdminOrOwner() && inCallersGym();
      allow delete: if isAdminOrOwner() && inCallersGym();
    }

    // ════════════════════════════════════════════════════════
    //  GYMS (global — multi-tenant registry)
    // ════════════════════════════════════════════════════════
    match /gyms/{gymId} {

      allow read: if isStaff();
      allow create: if isSuperAdmin() || (
        isAuthed() &&
        request.resource.data.ownerUid == request.auth.uid
      );
      allow update: if isAdminOrOwner();
      allow delete: if isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  SUBSCRIPTIONS (global — billing per gym)
    // ════════════════════════════════════════════════════════
    match /subscriptions/{subId} {

      allow read: if isAdminOrOwner() && inCallersGym();
      allow create: if isAdminOrOwner() && inCallersGymCreate();
      allow update: if isAdminOrOwner() && inCallersGym();
      allow delete: if isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  SUBSCRIPTION HISTORY (gym-scoped)
    // ════════════════════════════════════════════════════════
    match /subscriptionHistory/{historyId} {

      allow read: if isAdminOrOwner() && inCallersGym();
      allow create: if isAdminOrOwner() && inCallersGymCreate();
      allow delete: if isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  PAYMENT ATTEMPTS (PhonePe integration, gym-scoped)
    // ════════════════════════════════════════════════════════
    match /paymentAttempts/{attemptId} {

      allow read: if isAdminOrOwner() && inCallersGym();
      allow create: if isAdminOrOwner() && inCallersGymCreate();
      allow update: if isAdminOrOwner() && inCallersGym();
      allow delete: if isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  LICENSED DEVICES (gym-scoped — device registry)
    // ════════════════════════════════════════════════════════
    match /licensedDevices/{deviceId} {

      allow read: if isSuperAdmin() || (
        isGymAdmin() && resource.data.gymId == getCallerGymId()
      );

      allow create: if isStaff() && (
        isSuperAdmin() || request.resource.data.gymId == getCallerGymId()
      );

      allow update: if isSuperAdmin() || (
        isGymAdmin() && resource.data.gymId == getCallerGymId()
      );

      allow delete: if isSuperAdmin() || (
        isGymAdmin() && resource.data.gymId == getCallerGymId()
      );
    }

    // ════════════════════════════════════════════════════════
    //  LICENSE HISTORY (gym-scoped — audit log)
    // ════════════════════════════════════════════════════════
    match /licenseHistory/{historyId} {

      allow read: if isSuperAdmin() || (
        isGymAdmin() && resource.data.gymId == getCallerGymId()
      );

      allow create: if isAuthed();

      allow update: if isSuperAdmin();

      allow delete: if isSuperAdmin();
    }

    // ════════════════════════════════════════════════════════
    //  NOTIFICATIONS (user-scoped with gymId field)
    // ════════════════════════════════════════════════════════
    match /notifications/{notifId} {

      allow read: if isSuperAdmin() || (
        isAuthed() &&
        resource.data.userId == request.auth.uid &&
        (isSuperAdmin() || resource.data.gymId == getCallerGymId())
      );

      allow create: if isAuthed() && (
        isSuperAdmin() || (
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.gymId == getCallerGymId()
        )
      );

      allow update: if isSuperAdmin() || (
        isAuthed() &&
        resource.data.userId == request.auth.uid &&
        resource.data.gymId == getCallerGymId()
      );

      allow delete: if isSuperAdmin() || (
        isAuthed() &&
        resource.data.userId == request.auth.uid &&
        resource.data.gymId == getCallerGymId()
      );
    }

  } // end match /databases/{database}/documents
} // end service cloud.firestore

rules_version = '2';

// IRONPULSE — Firebase Storage Security Rules
// Authenticated users can read; any authenticated user can write to
// member photos and gym logos (further gated by the app layer).

service firebase.storage {
  match /b/{bucket}/o {

    // Member profile photos — read/write by any authenticated user
    match /members/{memberId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Gym logos — read/write by any authenticated user
    match /settings/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
